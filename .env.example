# Copy this file to `.env` and set ONE provider key. The app auto-detects which
# provider to use based on whichever key is present (free options first).

# --- Free options (recommended) ---
# Groq — free, fast, no credit card:  https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini — free tier:          https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# OpenRouter — free `:free` models:   https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# --- Paid option ---
# OpenAI:                             https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# --- Optional overrides ---
# Force a provider (groq | gemini | openrouter | openai):
# LLM_PROVIDER=groq
# Override the model for the active provider:
# LLM_MODEL=llama-3.3-70b-versatile

# Optional Gradio server binding.
# GRADIO_SERVER_NAME=0.0.0.0
# GRADIO_SERVER_PORT=7860
